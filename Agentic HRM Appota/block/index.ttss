/* ============================================
   Hiring Management Hub - Kinetic Polaris Styles
   Lark Block (ttss format)
   ============================================ */

/* ── Page Layout ─────────────────────────────────────────────────────── */
.page {
  display: flex;
  flex-direction: column;
  background-color: #fbf9f8;
  min-height: 100vh;
}

.main-scroll {
  flex: 1;
  margin-top: 88px;
  padding: 0 16px;
}

/* ─── Top App Bar ─────────────────────────────────────────────────────── */
.top-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 88px;
  background-color: #ffffff;
  border-bottom: 1px solid #c4c7c7;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 16px;
  z-index: 100;
  box-sizing: border-box;
}

.top-bar-left {
  display: flex;
  align-items: center;
}

.top-bar-title {
  font-size: 20px;
  font-weight: 650;
  color: #1b1c1c;
  letter-spacing: -0.2px;
}

.top-bar-right {
  display: flex;
  align-items: center;
}

.icon-btn {
  width: 40px;
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8px;
}

.icon-btn:active {
  background-color: #f5f3f3;
}

.icon {
  font-size: 22px;
  color: #1b1c1c;
  font-family: 'Material Symbols Outlined', sans-serif;
}

/* ─── Search Section ──────────────────────────────────────────────────── */
.search-section {
  margin-top: 16px;
  display: flex;
  flex-direction: column;
}

.search-bar {
  position: relative;
  display: flex;
  align-items: center;
  height: 44px;
  background-color: #ffffff;
  border: 1px solid #c4c7c7;
  border-radius: 8px;
  padding: 0 12px;
  box-sizing: border-box;
}

.search-icon {
  font-size: 20px;
  color: #747878;
  margin-right: 8px;
  font-family: 'Material Symbols Outlined', sans-serif;
}

.search-input {
  flex: 1;
  height: 44px;
  font-size: 14px;
  color: #1b1c1c;
}

.search-tune {
  font-size: 20px;
  color: #747878;
  margin-left: 8px;
  font-family: 'Material Symbols Outlined', sans-serif;
}

/* ─── Tabs ────────────────────────────────────────────────────────────── */
.tabs-scroll {
  margin-top: 12px;
  width: 100%;
  white-space: nowrap;
}

.tabs-row {
  display: flex;
  gap: 8px;
  padding-bottom: 4px;
}

.tab-btn {
  padding: 8px 16px;
  border-radius: 8px;
  font-size: 13px;
  white-space: nowrap;
  flex-shrink: 0;
}

.tab-btn text {
  font-size: 13px;
}

.tab-active {
  background-color: #0055c7;
}

.tab-active text {
  color: #ffffff;
  font-weight: 650;
}

.tab-inactive {
  background-color: transparent;
}

.tab-inactive text {
  color: #444748;
  font-weight: 500;
}

.tab-inactive:active {
  background-color: #e9e8e7;
}

/* ─── Filter Dropdowns ────────────────────────────────────────────────── */
.filters-row {
  display: flex;
  gap: 8px;
  margin-top: 12px;
}

.filter-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8px 12px;
  background-color: #ffffff;
  border: 1px solid #c4c7c7;
  border-radius: 8px;
}

.filter-btn:active {
  background-color: #f5f3f3;
}

.filter-text {
  font-size: 13px;
  color: #1b1c1c;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.filter-arrow {
  font-size: 18px;
  color: #747878;
  margin-left: 4px;
  font-family: 'Material Symbols Outlined', sans-serif;
}

/* ─── Job List ────────────────────────────────────────────────────────── */
.job-list {
  margin-top: 24px;
  display: flex;
  flex-direction: column;
  gap: 12px;
  padding-bottom: 16px;
}

/* ─── Job Card ────────────────────────────────────────────────────────── */
.job-card {
  background-color: #ffffff;
  border-radius: 12px;
  border: 1px solid #e3e3e3;
  box-shadow: 0 1px 0 0 rgba(26, 26, 26, 0.07);
  padding: 12px;
  box-sizing: border-box;
}

.job-card:active {
  background-color: #f5f3f3;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 8px;
}

.card-title {
  font-size: 14px;
  font-weight: 700;
  color: #1b1c1c;
  flex: 1;
  margin-right: 8px;
}

/* ─── Status Badges ───────────────────────────────────────────────────── */
.badge {
  padding: 2px 8px;
  border-radius: 9999px;
  flex-shrink: 0;
}

.badge-approved {
  background-color: #e6feda;
}

.badge-pending {
  background-color: #fff3e0;
}

.badge-rejected {
  background-color: #ffecef;
}

.badge-cc {
  background-color: #e8f0fe;
}

.badge-text {
  font-size: 10px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.3px;
}

.badge-approved .badge-text {
  color: #014b40;
}

.badge-pending .badge-text {
  color: #8a3a00;
}

.badge-rejected .badge-text {
  color: #8e0b21;
}

.badge-cc .badge-text {
  color: #0d47a1;
}

/* ─── Card Metadata ───────────────────────────────────────────────────── */
.card-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 4px 24px;
  margin-bottom: 12px;
}

.meta-col {
  display: flex;
  flex-direction: column;
  min-width: 120px;
}

.meta-label {
  font-size: 11px;
  color: #444748;
  margin-bottom: 2px;
}

.meta-value {
  font-size: 13px;
  font-weight: 500;
  color: #1b1c1c;
}

/* ─── Card Footer ─────────────────────────────────────────────────────── */
.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 8px;
  border-top: 1px solid #e9e8e7;
}

.footer-left {
  display: flex;
  align-items: center;
}

.avatar {
  width: 28px;
  height: 28px;
  border-radius: 50%;
  border: 1px solid rgba(196, 199, 199, 0.3);
  margin-right: 8px;
}

.requester-name {
  font-size: 13px;
  font-weight: 600;
  color: #1b1c1c;
}

.request-date {
  font-size: 11px;
  color: #747878;
}

/* ─── Empty / Loading States ──────────────────────────────────────────── */
.empty-state {
  display: flex;
  justify-content: center;
  padding: 48px 0;
}

.empty-text {
  font-size: 13px;
  color: #747878;
}

.loading-state {
  display: flex;
  justify-content: center;
  padding: 48px 0;
}

.spinner {
  width: 24px;
  height: 24px;
  border: 3px solid #c4c7c7;
  border-top-color: #0055c7;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* ─── Bottom Navigation ───────────────────────────────────────────────── */
.bottom-nav {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100px;
  background-color: #ffffff;
  border-top: 1px solid #c4c7c7;
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 100;
}

.nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 8px 12px;
  border-radius: 8px;
}

.nav-active {
  color: #0055c7;
}

.nav-active .nav-label {
  font-weight: 700;
}

.nav-inactive {
  color: #444748;
}

.nav-icon {
  font-size: 24px;
  font-family: 'Material Symbols Outlined', sans-serif;
  margin-bottom: 4px;
}

.nav-icon-filled {
  font-variation-settings: 'FILL' 1;
}

.nav-label {
  font-size: 11px;
}
