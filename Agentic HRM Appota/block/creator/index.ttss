.creator-page {
  padding: 24px 16px;
  background-color: #fbf9f8;
  min-height: 100%;
}

.creator-header {
  margin-bottom: 24px;
}

.creator-title {
  font-size: 20px;
  font-weight: 650;
  color: #1b1c1c;
}

.creator-section {
  margin-bottom: 20px;
  padding: 16px;
  background-color: #ffffff;
  border-radius: 12px;
  border: 1px solid #e3e3e3;
}

.section-label {
  font-size: 12px;
  font-weight: 500;
  color: #444748;
  margin-bottom: 6px;
  display: block;
}

.section-value {
  font-size: 14px;
  font-weight: 450;
  color: #1b1c1c;
  word-break: break-all;
}

.creator-footer {
  margin-top: 32px;
}

.save-btn {
  background-color: #303030;
  border-radius: 8px;
  padding: 14px 24px;
  text-align: center;
  box-shadow: 0 -1px 0 1px rgba(0, 0, 0, 0.8) inset;
}

.save-btn:active {
  opacity: 0.9;
}

.save-btn-text {
  color: #ffffff;
  font-size: 14px;
  font-weight: 500;
}
