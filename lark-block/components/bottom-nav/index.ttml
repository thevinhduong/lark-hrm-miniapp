<view class="bottom-nav {{navClass}}">
  <block wx:for="{{tabs}}" wx:key="key">
    <button
      class="nav-item {{item.label === activeTab ? 'active' : ''}}"
      data-tab="{{item.label}}"
      bindtap="onTabTap"
    >
      <text class="material-icon {{item.label === activeTab && item.iconFill ? 'filled' : ''}}">{{item.icon}}</text>
      <text class="nav-label">{{item.label}}</text>
    </button>
  </block>
</view>